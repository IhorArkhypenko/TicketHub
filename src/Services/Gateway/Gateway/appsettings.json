{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Identity": {
    "Authority": "http://localhost:5102"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-events-read": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/v1/events/{**catch-all}", "Methods": [ "GET" ] }
      },
      "catalog-sessions-read": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/v1/sessions/{**catch-all}", "Methods": [ "GET" ] }
      },
      "catalog-write": {
        "ClusterId": "catalog",
        "AuthorizationPolicy": "catalog.api",
        "Match": { "Path": "/api/v1/events/{**catch-all}", "Methods": [ "POST", "PUT", "DELETE", "PATCH" ] }
      },
      "booking": {
        "ClusterId": "booking",
        "AuthorizationPolicy": "booking.api",
        "Match": { "Path": "/api/v1/bookings/{**catch-all}" }
      }
    },
    "Clusters": {
      "catalog": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5101/" }
        }
      },
      "booking": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5104/" }
        }
      }
    }
  },
  "Observability": {
    "Loki": {
      "Endpoint": "http://localhost:3100"
    },
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  }
}
