{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Identity": {
    "Authority": "http://localhost:5102"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-read": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "/api/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "catalog-write": {
        "ClusterId": "catalog",
        "AuthorizationPolicy": "RequireApiScope",
        "Match": {
          "Path": "/api/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE", "PATCH" ]
        }
      }
    },
    "Clusters": {
      "catalog": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5101/"
          }
        }
      }
    }
  },
  "Observability": {
    "Loki": {
      "Endpoint": "http://localhost:3100"
    },
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  }
}
